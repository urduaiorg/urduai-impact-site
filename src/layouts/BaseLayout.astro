---
import "../styles/global.css";

const {
  title = "Urdu AI Impact",
  description = "Public evidence hub for Urdu AI's AI literacy work across Pakistan."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://impact.urduai.org/" />
    <meta property="og:image" content="https://impact.urduai.org/assets/training-hero.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800;9..40,900&family=Noto+Nastaliq+Urdu:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="container nav">
          <a class="brand" href="/">
            <span class="brand-mark">AI</span>
            <span>Urdu AI Impact</span>
          </a>
          <nav class="nav-links" aria-label="Primary">
            <a href="#numbers">Numbers</a>
            <a href="#map">Map</a>
            <a href="#stories">Stories</a>
            <a href="#recognition">Recognition</a>
            <a href="#reports">Reports</a>
          </nav>
          <a class="button secondary" href="https://urduai.org/">Visit UrduAI.org</a>
        </div>
      </header>
      <slot />
    </div>
  </body>
</html>
