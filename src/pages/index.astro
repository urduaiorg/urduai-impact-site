---
import BaseLayout from "../layouts/BaseLayout.astro";
import { stats, proofPoints, sectors, stories, impactQuotes, shorts, mediaVideos, recognition } from "../data/impact.js";
import { dostProfiles, teamProfiles } from "../data/profiles.js";

const storyImages = ["/assets/training-group.jpg", "/assets/dost-community.jpg", "/assets/classroom.jpg", "/assets/training-hero.jpg"];
const dostCards = dostProfiles.map((profile) => ({
  ...profile,
  summary: `${profile.bio.split(". ")[0]}.`
}));
const capacitySteps = [
  {
    step: "01",
    title: "Train Urdu Ai Dosts",
    text: "Urdu Ai prepares local facilitators with Urdu-first AI concepts, practical tool workflows, session materials, and field reporting discipline."
  },
  {
    step: "02",
    title: "Dosts take AI into their districts",
    text: "Dosts deliver sessions in schools, colleges, community spaces, vocational institutes, and local networks where English-first AI training rarely reaches."
  },
  {
    step: "03",
    title: "Communities learn through trusted people",
    text: "Learners see AI explained by someone from their own context, with examples for teaching, study, farming, freelancing, small business, and daily work."
  },
  {
    step: "04",
    title: "Learning continues online",
    text: "After the session, learners join Urdu Ai's 1M+ public learning ecosystem to keep practicing, asking questions, watching tutorials, and sharing progress."
  }
];
const showcaseImages = [
  {
    image: "/assets/showcase/women-community-workshop.jpg",
    title: "Women learn AI together",
    text: "Trusted spaces help women ask questions, practice in Urdu, and build confidence together."
  },
  {
    image: "/assets/showcase/school-computer-lab-workshop.jpg",
    title: "AI enters classrooms and labs",
    text: "Dosts turn formal learning spaces into practical AI sessions with tools learners can use immediately."
  },
  {
    image: "/assets/showcase/night-community-session.jpg",
    title: "AI reaches the last mile",
    text: "Learning does not stop at formal venues; Dosts also reach people in local evening gatherings."
  },
  {
    image: "/assets/showcase/women-dost-banner.jpg",
    title: "Women carry AI forward",
    text: "Women-led groups help carry Urdu Ai into schools, families, and community networks."
  }
];
const partnerBadges = [
  {
    label: "Implemented by",
    name: "WANG",
    image: "/assets/partners/wang-logo.png",
    variant: "wang"
  },
  {
    label: "In collaboration with",
    name: "AVPN",
    image: "/assets/partners/partner-avpn.svg"
  },
  {
    label: "Supported by",
    name: "Google.org",
    image: "/assets/partners/partner-google-org.png"
  },
  {
    label: "Supported by",
    name: "Asian Development Bank",
    image: "/assets/partners/partner-adb.png",
    variant: "square"
  }
];
const dostDistricts = [
  { district: "Lakki Marwat", province: "KPK", lat: 32.607, lng: 70.911, count: 1 },
  { district: "Bhakkar", province: "Punjab", lat: 31.626, lng: 71.066, count: 1 },
  { district: "Layyah", province: "Punjab", lat: 30.969, lng: 70.944, count: 1 },
  { district: "Pishin", province: "Balochistan", lat: 30.583, lng: 67.0, count: 1 },
  { district: "Pakpattan", province: "Punjab", lat: 30.343, lng: 73.386, count: 1 },
  { district: "Rawalpindi", province: "Punjab", lat: 33.565, lng: 73.016, count: 1 },
  { district: "Quetta", province: "Balochistan", lat: 30.179, lng: 66.975, count: 2 },
  { district: "Musakhail", province: "Balochistan", lat: 30.775, lng: 69.822, count: 1 },
  { district: "Khanewal", province: "Punjab", lat: 30.301, lng: 71.933, count: 1 },
  { district: "Mianwali", province: "Punjab", lat: 32.586, lng: 71.544, count: 1 },
  { district: "Chiniot", province: "Punjab", lat: 31.72, lng: 72.979, count: 1 },
  { district: "Bahawalnagar", province: "Punjab", lat: 29.999, lng: 73.253, count: 1 },
  { district: "Islamabad", province: "ICT", lat: 33.693, lng: 73.065, count: 1 },
  { district: "Rahim Yar Khan", province: "Punjab", lat: 28.421, lng: 70.298, count: 1 },
  { district: "Malakand", province: "KPK", lat: 34.565, lng: 71.93, count: 1 },
  { district: "Panjgur", province: "Balochistan", lat: 26.964, lng: 64.1, count: 1 },
  { district: "Dera Ismail Khan", province: "KPK", lat: 31.831, lng: 70.902, count: 1 },
  { district: "Khairpur Mir's", province: "Sindh", lat: 27.529, lng: 68.759, count: 1 },
  { district: "Sibi", province: "Balochistan", lat: 29.544, lng: 67.878, count: 1 },
  { district: "Multan", province: "Punjab", lat: 30.157, lng: 71.524, count: 1 },
  { district: "Vehari", province: "Punjab", lat: 30.045, lng: 72.355, count: 1 },
  { district: "Hyderabad", province: "Sindh", lat: 25.379, lng: 68.368, count: 1 },
  { district: "Dadu", province: "Sindh", lat: 26.73, lng: 67.776, count: 1 },
  { district: "Nasirabad", province: "Balochistan", lat: 28.35, lng: 68.7, count: 1 },
  { district: "Lahore", province: "Punjab", lat: 31.52, lng: 74.358, count: 1 },
  { district: "Chakwal", province: "Punjab", lat: 32.93, lng: 72.857, count: 1 },
  { district: "Mirpur Khas", province: "Sindh", lat: 25.525, lng: 69.012, count: 1 },
  { district: "Lasbela", province: "Balochistan", lat: 25.807, lng: 66.621, count: 2 },
  { district: "Hub Chowki", province: "Balochistan", lat: 25.121, lng: 66.882, count: 1 }
];
const provinceSummary = [
  ["Punjab", "13 Dosts"],
  ["Balochistan", "10 Dosts"],
  ["Sindh", "4 Dosts"],
  ["KPK", "3 Dosts"],
  ["ICT", "1 Dost"]
];
const provinceColors = {
  Punjab: "#2e549a",
  Balochistan: "#d39b24",
  Sindh: "#2f9d86",
  KPK: "#7c63c7",
  ICT: "#cf5d88"
};
const mapBounds = { minLng: 60.8, maxLng: 77.2, minLat: 23.4, maxLat: 37.1 };
const mapPoints = dostDistricts.map((point) => ({
  ...point,
  x: ((point.lng - mapBounds.minLng) / (mapBounds.maxLng - mapBounds.minLng)) * 100,
  y: ((mapBounds.maxLat - point.lat) / (mapBounds.maxLat - mapBounds.minLat)) * 100,
  color: provinceColors[point.province] || provinceColors.Punjab
}));
---

<BaseLayout
  title="Urdu Ai Impact | Reported AI Literacy Reach Across Pakistan"
  description="Impact evidence, learner records, district coverage, Urdu Ai Dost stories, media coverage, and recognition for Urdu Ai's AI literacy work across Pakistan."
>
  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-content" data-reveal>
          <h1><span>Urdu</span> <span class="brand-ai">Ai</span> <span>Impact</span></h1>
          <p class="urdu-line hero-urdu">آسان اردو میں مصنوعی ذہانت کو سمجھنے کا سب سے معتبر پلیٹ فارم</p>
          <p class="hero-copy">
            Public evidence of what changes when artificial intelligence learning is delivered in Urdu, through local trainers, community partners, and practical tools people can use immediately.
          </p>
          <div class="hero-actions">
            <a class="button" href="#numbers">See the numbers</a>
            <a class="button secondary" href="#stories">Watch field stories</a>
          </div>
          <p class="data-note">
            Impact figures are presented as reported learner records and training completions. They should not be read as verified unique beneficiaries unless explicitly stated.
          </p>
        </div>
        <div class="hero-media" aria-label="Urdu Ai field training photos" data-reveal>
          <img src="/assets/training-hero.jpg" alt="Urdu Ai training session with learners in Pakistan" />
          <img src="/assets/classroom.jpg" alt="Learners attending an AI education session" />
          <img src="/assets/dost-community.jpg" alt="Urdu Ai Dost community group" />
          <img src="/assets/training-group.jpg" alt="Urdu Ai facilitators and participants" />
          <div class="hero-photo-note">
            <strong>29 districts</strong>
            <span>Local Dost presence turning online learning into community access.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section alt" id="numbers" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Numbers that can be explained.</h2>
          <p class="section-lede">
            The impact site keeps headline metrics visible, but also gives partners the reporting basis behind them.
          </p>
        </div>
        <div class="stats-grid">
          {stats.map((stat) => (
            <article class="stat">
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
              <p>{stat.note}</p>
            </article>
          ))}
        </div>
        <ul class="proof-grid">
          {proofPoints.map((point) => <li>{point}</li>)}
        </ul>
      </div>
    </section>

    <section class="section" id="map" data-reveal>
      <div class="container map-band">
        <div class="map-card">
          <span class="map-number">29</span>
          <h2>Districts with Urdu Ai Dost presence.</h2>
          <p>
            The Dost network turns a digital platform into local access: training rooms, campus sessions, community cohorts, women-friendly participation pathways, and follow-up support.
          </p>
          <div class="map-summary-chips" aria-label="Urdu Ai Dost map summary">
            <span><strong>31</strong> active Dost records</span>
            <span><strong>5</strong> regions represented</span>
          </div>
        </div>
        <div class="dost-map-panel">
          <div class="dost-network-map" aria-label="Map showing Urdu Ai Dost district presence">
            <svg class="pakistan-shape" viewBox="0 0 100 100" aria-hidden="true">
              <path d="M55 5C61 8 65 12 68 18C65 23 69 28 66 33C72 38 71 46 76 53C82 61 78 70 72 76C68 80 66 87 63 94C58 98 52 95 49 89C45 81 39 78 35 70C31 63 24 60 20 52C16 44 18 36 24 30C30 24 32 17 38 12C43 8 48 3 55 5Z"></path>
              <path class="coastline" d="M36 70C42 79 50 84 56 93"></path>
              <path class="region-line" d="M38 13C48 24 58 28 66 33"></path>
              <path class="region-line" d="M22 52C36 48 50 48 66 33"></path>
              <path class="region-line" d="M36 70C45 63 58 59 76 53"></path>
            </svg>
            <span class="map-region-label map-region-north">KPK / ICT</span>
            <span class="map-region-label map-region-east">Punjab</span>
            <span class="map-region-label map-region-west">Balochistan</span>
            <span class="map-region-label map-region-south">Sindh</span>
            {mapPoints.map((point) => (
              <span
                class:list={["map-pin", point.count > 1 && "map-pin--strong"]}
                style={`--x:${point.x.toFixed(2)}%; --y:${point.y.toFixed(2)}%; --pin:${point.color};`}
                title={`${point.district}, ${point.province}: ${point.count} Dost ${point.count === 1 ? "record" : "records"}`}
                aria-label={`${point.district}, ${point.province}: ${point.count} Dost ${point.count === 1 ? "record" : "records"}`}
              >
                {point.count > 1 ? point.count : ""}
              </span>
            ))}
          </div>
          <div class="map-legend" aria-label="Urdu Ai Dost province summary">
            {provinceSummary.map(([province, label]) => (
              <span>
                <i class={`province-dot province-${province.toLowerCase().replaceAll(" ", "-")}`}></i>
                <strong>{province}</strong>
                {label}
              </span>
            ))}
          </div>
        </div>
        <div class="district-list" aria-label="Urdu Ai delivery channels">
          <div><strong>Schools and colleges</strong><br />AI awareness, teacher workflows, student research, and classroom use.</div>
          <div><strong>Women and girls</strong><br />51% women participation shown through safer access, trusted settings, and follow-up learning.</div>
          <div><strong>Community cohorts</strong><br />Local facilitators helping first-time learners build confidence.</div>
          <div><strong>Freelancers and MSMEs</strong><br />Design, content, customer service, documentation, and productivity workflows.</div>
        </div>
      </div>
    </section>

    <section class="section capacity-section" id="model" data-reveal>
      <div class="container">
        <div class="capacity-hero">
          <div>
            <span class="eyebrow">Capacity building model</span>
            <h2>Urdu Ai does not stop at one workshop.</h2>
            <p>
              The model builds local capacity first. Urdu Ai trains Dosts, Dosts train their own communities, and learners continue inside Urdu Ai's 1M+ online learning ecosystem.
            </p>
          </div>
          <div class="capacity-metrics" aria-label="Urdu Ai capacity building signals">
            <div>
              <strong>30+</strong>
              <span>Dost facilitators supporting local learning</span>
            </div>
            <div>
              <strong>29</strong>
              <span>Districts represented in public delivery evidence</span>
            </div>
            <div>
              <strong>1M+</strong>
              <span>Online community for continued Urdu-first AI learning</span>
            </div>
          </div>
        </div>

        <div class="model-flow" aria-label="How Urdu Ai capacity building works">
          {capacitySteps.map((item) => (
            <article class="model-step">
              <span>{item.step}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>

        <div class="showcase-grid" aria-label="Visual showcase of how Urdu Ai works">
          {showcaseImages.map((item, index) => (
            <figure class:list={["showcase-tile", index === 0 && "wide"]}>
              <img src={item.image} alt={item.title} loading="lazy" />
              <figcaption>
                <strong>{item.title}</strong>
                <span>{item.text}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="section alt profile-section" id="dosts" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Dost profiles show the delivery network.</h2>
          <p class="section-lede">
            The Dost model is the human layer behind Urdu Ai's district reach: educators, organizers, technologists, advocates, and community leaders who make AI learning local.
          </p>
        </div>
        <div class="profile-summary">
          <div>
            <strong>31</strong>
            <span>Active Dosts reported on the current impact site</span>
          </div>
          <div>
            <strong>{dostProfiles.length}</strong>
            <span>Public Dost profiles currently available from the WordPress directory</span>
          </div>
          <div>
            <strong>29</strong>
            <span>Districts represented in the public impact map</span>
          </div>
        </div>
        <div class="dost-grid">
          {dostCards.map((profile) => (
            <article class="profile-card dost-card">
              <img src={profile.image} alt={`${profile.name}, Urdu Ai Dost in ${profile.district}`} loading="lazy" />
              <div class="profile-card-body">
                <span class="profile-location">{profile.district}</span>
                <h3>{profile.name}</h3>
                <p>{profile.summary}</p>
                <details>
                  <summary>Read profile</summary>
                  <p>{profile.bio}</p>
                </details>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section alt" id="stories" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Field stories, not just totals.</h2>
          <p class="section-lede">
            Urdu Ai tracks applied use: how learners move from awareness to confidence, productivity, and livelihood pathways.
          </p>
        </div>
        <div class="stories-grid">
          {stories.map((story, index) => (
            <article class="story">
              <img src={storyImages[index]} alt={story.title} />
              <div>
                <h3>{story.title}</h3>
                <p>{story.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section quote-section" data-reveal>
      <div class="container quote-band">
        <div class="quote-intro">
          <h2>Impact sounds like confidence.</h2>
          <p>
            The public site should carry the numbers, but the writing also needs to show what changes for people when AI becomes understandable in Urdu.
          </p>
        </div>
        <div class="quote-stack" aria-label="Urdu Ai impact themes">
          {impactQuotes.map((item) => (
            <figure class="impact-quote">
              <blockquote>{item.quote}</blockquote>
              <figcaption>
                <strong>{item.source}</strong>
                <span>{item.note}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="section" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Latest impact Shorts.</h2>
          <p class="section-lede">
            Short, mobile-first evidence from learners, teachers, Dosts, farmers, and communities using AI in everyday work.
          </p>
        </div>
        <div class="shorts-grid">
          {shorts.map(([id, title]) => (
            <article class="short-card">
              <iframe src={`https://www.youtube.com/embed/${id}`} title={title} loading="lazy" allowfullscreen></iframe>
              <p>{title}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section alt" id="recognition" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Recognition and partners.</h2>
          <p class="section-lede">
            This initiative is part of the AI Opportunity Fund: Asia-Pacific, implemented by WANG in collaboration with AVPN and supported by Google.org and the Asian Development Bank (ADB).
          </p>
        </div>
        <div class="partner-badge-grid" aria-label="AI Opportunity Fund partner badges">
          {partnerBadges.map((partner) => (
            <article class:list={["partner-badge", partner.variant && `partner-badge--${partner.variant}`]}>
              <span>{partner.label}</span>
              <div class="partner-logo-frame">
                <img src={partner.image} alt={partner.name} loading="lazy" />
              </div>
              <strong>{partner.name}</strong>
            </article>
          ))}
        </div>
        <div class="recognition-grid">
          {recognition.map((item) => (
            <article class="recognition-card">
              <h3>{item.name}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section profile-section" id="team" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>The team accountable for the work.</h2>
          <p class="section-lede">
            The impact site should make leadership visible: programme direction, field management, content, media, and gender perspectives.
          </p>
        </div>
        <div class="team-grid">
          {teamProfiles.map((profile) => (
            <article class="profile-card team-card">
              <img src={profile.image} alt={profile.name} loading="lazy" />
              <div class="profile-card-body">
                <span class="profile-location">{profile.role}</span>
                <h3>{profile.name}</h3>
                <p>{profile.bio}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Who Urdu Ai reached.</h2>
          <p class="section-lede">
            Phase 2 completion data includes learners across education, employment, social sector, and small business contexts.
          </p>
        </div>
        <table class="sector-table">
          <thead>
            <tr>
              <th>Reported learner group</th>
              <th>Records</th>
            </tr>
          </thead>
          <tbody>
            {sectors.map(([sector, count]) => (
              <tr>
                <td>{sector}</td>
                <td>{count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="section alt" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Media coverage.</h2>
          <p class="section-lede">
            National and regional media coverage helps document Urdu Ai's public visibility and momentum.
            Source channel: @UrduAiinMedia.
          </p>
        </div>
        <div class="media-grid">
          {mediaVideos.map(([id, title]) => (
            <article class="media-card">
              <iframe src={`https://www.youtube.com/embed/${id}`} title={title} loading="lazy" allowfullscreen></iframe>
              <p>{title}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="reports" data-reveal>
      <div class="container report-band">
        <article class="report-panel">
          <h3>Impact reporting that donors can read quickly.</h3>
          <p>
            The site can publish quarterly impact briefs, district snapshots, media packs, and a transparent methodology note while LinkedIn carries current learner stories.
          </p>
          <a class="button" href="mailto:ai@urduai.org">Contact Urdu Ai</a>
        </article>
        <article class="report-panel">
          <h3>Methodology note.</h3>
          <p>
            Current headline numbers combine reported training completions and learner records. Contact fields and shared institutional records are treated carefully and not overclaimed as unique verified people.
          </p>
          <a class="button secondary" href="#numbers">Review reporting basis</a>
        </article>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-row">
      <p>Urdu Ai Impact is the public evidence hub for Urdu Ai's learning and community delivery work.</p>
      <p>
        Built for clear partner reporting with public, audit-defensible language.
        <a href="https://www.linkedin.com/company/urduaiorg/">Latest public updates on LinkedIn</a>
      </p>
    </div>
  </footer>
  <script is:inline>
    const revealItems = document.querySelectorAll("[data-reveal]");

    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { rootMargin: "0px 0px -10% 0px", threshold: 0.16 }
      );

      revealItems.forEach((item) => observer.observe(item));
    } else {
      revealItems.forEach((item) => item.classList.add("is-visible"));
    }
  </script>
</BaseLayout>
