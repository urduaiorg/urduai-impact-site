---
import BaseLayout from "../layouts/BaseLayout.astro";
import { stats, proofPoints, sectors, stories, learnerOutcomes, impactQuotes, shorts, mediaVideos, recognition } from "../data/impact.js";
import { institutionalPartners, institutionalEvidence } from "../data/institutions.js";
import { dostProfiles, teamProfiles } from "../data/profiles.js";

const storyImages = ["/assets/training-group.jpg", "/assets/dost-community.jpg", "/assets/classroom.jpg", "/assets/training-hero.jpg"];
const dostCards = dostProfiles.map((profile) => ({
  ...profile,
  summary: `${profile.bio.split(". ")[0]}.`
}));
const capacitySteps = [
  {
    step: "01",
    title: "Train Urdu Ai Dosts",
    text: "Urdu Ai prepares local facilitators with Urdu-first AI concepts, practical tool workflows, session materials, and field reporting discipline."
  },
  {
    step: "02",
    title: "Dosts take AI into their districts",
    text: "Dosts deliver sessions in schools, colleges, community spaces, vocational institutes, and local networks where English-first AI training rarely reaches."
  },
  {
    step: "03",
    title: "Communities learn through trusted people",
    text: "Learners see AI explained by someone from their own context, with examples for teaching, study, farming, freelancing, small business, and daily work."
  },
  {
    step: "04",
    title: "Learning continues online",
    text: "After the session, learners join Urdu Ai's 1M+ public learning ecosystem to keep practicing, asking questions, watching tutorials, and sharing progress."
  }
];
const showcaseImages = [
  {
    image: "/assets/showcase/women-community-workshop.jpg",
    title: "Women learn AI together",
    text: "Trusted spaces help women ask questions, practice in Urdu, and build confidence together."
  },
  {
    image: "/assets/showcase/school-computer-lab-workshop.jpg",
    title: "AI enters classrooms and labs",
    text: "Dosts turn formal learning spaces into practical AI sessions with tools learners can use immediately."
  },
  {
    image: "/assets/showcase/night-community-session.jpg",
    title: "AI reaches the last mile",
    text: "Learning does not stop at formal venues; Dosts also reach people in local evening gatherings."
  },
  {
    image: "/assets/showcase/women-dost-banner.jpg",
    title: "Women carry AI forward",
    text: "Women-led groups help carry Urdu Ai into schools, families, and community networks."
  }
];
const investmentCase = [
  {
    label: "The access gap",
    title: "AI is arriving faster than language equity.",
    text: "Most AI learning still assumes English comfort, urban confidence, and self-directed online study. Urdu Ai lowers the first barrier by making AI understandable in the language people already use."
  },
  {
    label: "The delivery advantage",
    title: "WANG brings field trust, not just a digital channel.",
    text: "The model combines Urdu Ai's national media ecosystem with WANG's long-standing community delivery experience, local facilitators, women-friendly settings, and district-level follow-up."
  },
  {
    label: "The funder opportunity",
    title: "A path toward Pakistan's public-interest AI literacy infrastructure.",
    text: "Partner support can convert mass awareness into deeper learning pathways, livelihood use cases, teacher support, and district evidence that is easy to inspect and improve."
  }
];
const fundingPriorities = [
  {
    label: "District expansion",
    title: "Take Urdu-first AI learning into more underserved districts.",
    text: "Support Dost-led training, local venue costs, travel, district coordination, and follow-up cohorts where digital reach alone is not enough.",
    proof: "Builds from the current 29-district evidence base."
  },
  {
    label: "Women-led pathways",
    title: "Deepen safer, trusted AI learning spaces for women and girls.",
    text: "Fund women-friendly cohorts, female facilitators, community access points, and applied learning tracks for education, livelihood, and confidence.",
    proof: "Anchored in the reported 51% women participation signal."
  },
  {
    label: "Teacher and livelihood tracks",
    title: "Turn awareness into practical skills people use every week.",
    text: "Create structured Urdu learning pathways for teachers, freelancers, students, MSMEs, rural workers, and first-time AI users.",
    proof: "Connects mass media reach to measurable learning outcomes."
  },
  {
    label: "Impact evidence",
    title: "Make district impact easier to verify, compare, and improve.",
    text: "Strengthen reporting tools, story collection, dashboards, partner briefs, consented testimonials, and public evidence packs.",
    proof: "Moves the site from reporting totals to funder-grade evidence."
  }
];
const evidencePack = [
  "Reported learner records and completion basis",
  "District-level Dost map and facilitator profiles",
  "Partner and award references",
  "Media coverage and public learning videos",
  "Methodology note for non-overclaimed numbers"
];
const partnerBadges = [
  {
    label: "Implemented by",
    name: "WANG",
    image: "/assets/partners/wang-logo.png",
    variant: "wang"
  },
  {
    label: "In collaboration with",
    name: "AVPN",
    image: "/assets/partners/partner-avpn.svg"
  },
  {
    label: "Supported by",
    name: "Google.org",
    image: "/assets/partners/partner-google-org.png"
  },
  {
    label: "Supported by",
    name: "Asian Development Bank",
    image: "/assets/partners/partner-adb.png",
    variant: "square"
  }
];
const provinceSummary = [
  ["Punjab", "13 Dosts"],
  ["Balochistan", "10 Dosts"],
  ["Sindh", "4 Dosts"],
  ["KPK", "3 Dosts"],
  ["ICT", "1 Dost"]
];
const credibilitySignals = [
  "AI Opportunity Fund: Asia-Pacific",
  "Supported by Google.org and ADB",
  "S&P Global Foundation StepForward",
  "WANG field delivery ecosystem"
];
---

<BaseLayout
  title="Urdu Ai Impact | Reported AI Literacy Reach Across Pakistan"
  description="Impact evidence, learner records, district coverage, Urdu Ai Dost stories, media coverage, and recognition for Urdu Ai's AI literacy work across Pakistan."
  canonical="https://impact.urduai.org/"
>
  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-content" data-reveal>
          <div class="credibility-row" aria-label="Urdu Ai credibility signals">
            {credibilitySignals.map((item) => <span>{item}</span>)}
          </div>
          <h1><span>Pakistan's Urdu-first AI literacy movement.</span></h1>
          <p class="urdu-line hero-urdu">آسان اردو میں مصنوعی ذہانت کو سمجھنے کا سب سے معتبر پلیٹ فارم</p>
          <p class="hero-copy">
            Urdu Ai turns artificial intelligence from an English-only advantage into practical learning for students, teachers, women, freelancers, farmers, and community leaders across Pakistan.
          </p>
          <div class="hero-actions">
            <a class="button" href="#map">Explore the impact atlas</a>
            <a class="button secondary" href="#recognition">See partners</a>
          </div>
        </div>
        <div class="hero-atlas" aria-label="Urdu Ai impact evidence preview" data-reveal>
          <div class="atlas-photo">
            <img src="/assets/showcase/women-community-workshop.jpg" alt="Women participating in an Urdu Ai community workshop" />
            <div class="atlas-caption">
              <strong>51%</strong>
              <span>women participation across reported activity</span>
            </div>
          </div>
          <div class="atlas-proof-card">
            <span class="proof-label">Reported reach</span>
            <strong>13,569+</strong>
            <p>Learner records combined from Phase 2 completions and May reporting.</p>
          </div>
          <div class="atlas-proof-card dark">
            <span class="proof-label">Local delivery</span>
            <strong>29</strong>
            <p>Districts represented through Urdu Ai Dost public evidence.</p>
          </div>
          <div class="atlas-mini-grid">
            <img src="/assets/showcase/school-computer-lab-workshop.jpg" alt="Urdu Ai Dost delivering a school computer lab session" />
            <img src="/assets/showcase/night-community-session.jpg" alt="Urdu Ai Dost delivering a night community session" />
          </div>
        </div>
      </div>
    </section>

    <section class="investment-strip" aria-label="Why Urdu Ai matters to funders" data-reveal>
      <div class="container investment-grid">
        <div class="investment-lead">
          <span class="eyebrow">Investment case</span>
          <h2>Fund the bridge between AI possibility and real access.</h2>
        </div>
        <div class="investment-cards">
          {investmentCase.map((item) => (
            <article class="investment-card">
              <span>{item.label}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section alt" id="numbers" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Reported numbers with a clear basis.</h2>
          <p class="section-lede">
            Headline metrics are paired with the reporting basis behind them, so partners can see both scale and evidence.
          </p>
        </div>
        <div class="stats-grid">
          {stats.map((stat) => (
            <article class="stat">
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
              <p>{stat.note}</p>
            </article>
          ))}
        </div>
        <ul class="proof-grid">
          {proofPoints.map((point) => <li>{point}</li>)}
        </ul>
        <p class="data-note">
          Impact figures are presented as reported learner records and training completions. They are not counted as verified unique beneficiaries unless explicitly stated.
        </p>
      </div>
    </section>

    <section class="section atlas-section" id="map" data-reveal>
      <div class="container map-band">
        <div class="map-card">
          <div class="map-kicker">
            <span class="map-number">29</span>
            <span>districts represented</span>
          </div>
          <div class="map-copy">
            <h2>Impact Atlas: district evidence, not a generic reach claim.</h2>
            <p>
              The Dost network turns a digital platform into local access: training rooms, campus sessions, community cohorts, women-friendly participation pathways, and follow-up support that funders can inspect district by district.
            </p>
            <div class="map-summary-chips" aria-label="Urdu Ai Dost map summary">
              <span><strong>31</strong> active Dost records</span>
              <span><strong>5</strong> regions represented</span>
              <span><strong>1M+</strong> public learning ecosystem</span>
            </div>
          </div>
        </div>
        <div class="dost-map-panel">
          <iframe class="dost-map-iframe" src="/dost-map/" title="Interactive Urdu Ai Dost district map" loading="lazy"></iframe>
          <div class="map-legend" aria-label="Urdu Ai Dost province summary">
            {provinceSummary.map(([province, label]) => (
              <span>
                <i class={`province-dot province-${province.toLowerCase().replaceAll(" ", "-")}`}></i>
                <strong>{province}</strong>
                {label}
              </span>
            ))}
          </div>
          <a class="map-open-link" href="/dost-map/">Open full-screen Dost map</a>
        </div>
        <div class="atlas-notes" aria-label="How to read the Urdu Ai impact atlas">
          <article>
            <strong>Read the dots as delivery capacity.</strong>
            <p>Each marker represents a reported Dost record connected to local AI literacy delivery, not an inflated beneficiary claim.</p>
          </article>
          <article>
            <strong>Filter by province.</strong>
            <p>Use the full-screen map to inspect Punjab, Balochistan, Sindh, KPK, and ICT coverage with district-level context.</p>
          </article>
          <article>
            <strong>Follow the tour.</strong>
            <p>The impact tour moves funders through the Dost network as a national delivery system rather than a static total.</p>
          </article>
        </div>
        <div class="district-list" aria-label="Urdu Ai delivery channels">
          <div><strong>Schools and colleges</strong><br />AI awareness, teacher workflows, student research, and classroom use.</div>
          <div><strong>Women and girls</strong><br />51% women participation shown through safer access, trusted settings, and follow-up learning.</div>
          <div><strong>Community cohorts</strong><br />Local facilitators helping first-time learners build confidence.</div>
          <div><strong>Freelancers and MSMEs</strong><br />Design, content, customer service, documentation, and productivity workflows.</div>
        </div>
      </div>
    </section>

    <section class="section capacity-section" id="model" data-reveal>
      <div class="container">
        <div class="capacity-hero">
          <div>
            <span class="eyebrow">Capacity building model</span>
            <h2>Urdu Ai does not stop at one workshop.</h2>
            <p>
              The model builds local capacity first. Urdu Ai trains Dosts, Dosts train their own communities, and learners continue inside Urdu Ai's 1M+ online learning ecosystem.
            </p>
          </div>
          <div class="capacity-metrics" aria-label="Urdu Ai capacity building signals">
            <div>
              <strong>30+</strong>
              <span>Dost facilitators supporting local learning</span>
            </div>
            <div>
              <strong>29</strong>
              <span>Districts represented in public delivery evidence</span>
            </div>
            <div>
              <strong>1M+</strong>
              <span>Online community for continued Urdu-first AI learning</span>
            </div>
          </div>
        </div>

        <div class="model-flow" aria-label="How Urdu Ai capacity building works">
          {capacitySteps.map((item) => (
            <article class="model-step">
              <span>{item.step}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>

        <div class="showcase-grid" aria-label="Visual showcase of how Urdu Ai works">
          {showcaseImages.map((item, index) => (
            <figure class:list={["showcase-tile", index === 0 && "wide"]}>
              <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
              <figcaption>
                <strong>{item.title}</strong>
                <span>{item.text}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="section alt profile-section" id="dosts" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Dost profiles show the delivery network.</h2>
          <p class="section-lede">
            The Dost model is the human layer behind Urdu Ai's district reach: educators, organizers, technologists, advocates, and community leaders who make AI learning local.
          </p>
        </div>
        <div class="profile-summary">
          <div>
            <strong>31</strong>
            <span>Active Dost records in the public network</span>
          </div>
          <div>
            <strong>{dostProfiles.length}</strong>
            <span>Public Dost profiles available for partner review</span>
          </div>
          <div>
            <strong>29</strong>
            <span>Districts represented in the public impact map</span>
          </div>
        </div>
        <div class="dost-grid">
          {dostCards.map((profile) => (
            <article class="profile-card dost-card">
              <img src={profile.image} alt={`${profile.name}, Urdu Ai Dost in ${profile.district}`} loading="lazy" decoding="async" />
              <div class="profile-card-body">
                <span class="profile-location">{profile.district}</span>
                <h3>{profile.name}</h3>
                <p>{profile.summary}</p>
                <details>
                  <summary>Read profile</summary>
                  <p>{profile.bio}</p>
                </details>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section alt" id="stories" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Field stories, not just totals.</h2>
          <p class="section-lede">
            Urdu Ai tracks applied use: how learners move from awareness to confidence, productivity, and livelihood pathways.
          </p>
        </div>
        <div class="stories-grid">
          {stories.map((story, index) => (
            <article class="story">
              <img src={storyImages[index]} alt={story.title} loading="lazy" decoding="async" />
              <div>
                <h3>{story.title}</h3>
                <p>{story.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section outcome-section" id="outcomes" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Learners are turning AI into study, work, and income.</h2>
          <p class="section-lede">
            Written testimonials show the shift from first-time AI exposure to practical use: faster study work, paid design services, local business tools, and professional productivity.
          </p>
        </div>
        <div class="outcome-grid">
          {learnerOutcomes.map((outcome) => (
            <article class="outcome-card">
              <div class="outcome-signal">
                <span>{outcome.location}</span>
                <strong>{outcome.signal}</strong>
              </div>
              <h3>{outcome.title}</h3>
              <p>{outcome.text}</p>
              <div class="outcome-person">
                <strong>{outcome.name}</strong>
                <span>{outcome.role}</span>
              </div>
              <p class="outcome-tools">{outcome.tools}</p>
            </article>
          ))}
        </div>
        <p class="data-note">
          These cards are paraphrased from written learner testimonials submitted in May 2026. Reported time savings and income outcomes are learner-reported and should be read as testimonial evidence, not independently audited financial data.
        </p>
      </div>
    </section>

    <section class="section quote-section" data-reveal>
      <div class="container quote-band">
        <div class="quote-intro">
          <h2>Impact sounds like confidence.</h2>
          <p>
            The numbers matter, but the deeper shift is confidence: learners begin using AI in their own language for study, teaching, work, and everyday problem solving.
          </p>
        </div>
        <div class="quote-stack" aria-label="Urdu Ai impact themes">
          {impactQuotes.map((item) => (
            <figure class="impact-quote">
              <blockquote>{item.quote}</blockquote>
              <figcaption>
                <strong>{item.source}</strong>
                <span>{item.note}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="section" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Latest impact Shorts.</h2>
          <p class="section-lede">
            Short, mobile-first evidence from learners, teachers, Dosts, farmers, and communities using AI in everyday work.
          </p>
        </div>
        <div class="shorts-grid">
          {shorts.map(([id, title]) => (
            <article class="short-card">
              <iframe src={`https://www.youtube.com/embed/${id}`} title={title} loading="lazy" allowfullscreen></iframe>
              <p>{title}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section alt" id="recognition" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Recognition and partners.</h2>
          <p class="section-lede">
            This initiative is part of the AI Opportunity Fund: Asia-Pacific, implemented by WANG in collaboration with AVPN and supported by Google.org and the Asian Development Bank (ADB).
          </p>
        </div>
        <div class="partner-badge-grid" aria-label="AI Opportunity Fund partner badges">
          {partnerBadges.map((partner) => (
            <article class:list={["partner-badge", partner.variant && `partner-badge--${partner.variant}`]}>
              <span>{partner.label}</span>
              <div class="partner-logo-frame">
                <img src={partner.image} alt={partner.name} loading="lazy" decoding="async" />
              </div>
              <strong>{partner.name}</strong>
            </article>
          ))}
        </div>
        <div class="recognition-grid">
          {recognition.map((item) => (
            <article class="recognition-card">
              <h3>{item.name}</h3>
              <p>{item.text}</p>
              {item.url && <a href={item.url}>View reference</a>}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section institution-section" id="institutions" data-reveal>
      <div class="container">
        <div class="institution-head">
          <div>
            <span class="eyebrow">Institutional partnerships</span>
            <h2>Formal MoUs turn Urdu Ai into an education partner, not just a campaign.</h2>
          </div>
          <p>
            Universities, women-focused institutes, technical and vocational partners, and local education partners create trusted entry points for students, faculty, and communities. These agreements make it easier to schedule training, document delivery, and scale AI learning through existing institutions.
          </p>
        </div>

        <div class="institution-feature-grid">
          {institutionalPartners.map((partner) => (
            <article class="institution-card">
              <img src={partner.image} alt={`${partner.institution} Urdu Ai MoU`} loading="lazy" decoding="async" />
              <div>
                <span>{partner.place}</span>
                <h3>{partner.institution}</h3>
                <p>{partner.focus}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="institution-proof">
          <article class="institution-proof-copy">
            <strong>Why this matters to funders</strong>
            <p>
              Institutional partnerships reduce delivery friction. Urdu Ai can work through campuses, polytechnic institutes, local academies, and public-sector relationships where learners already gather and where follow-up is easier to organize.
            </p>
            <ul>
              <li>MoUs with women-focused and regional universities</li>
              <li>Technical and vocational training access for employability pathways</li>
              <li>Training pathways for students, youth, and faculty</li>
              <li>Public-sector relationship building and local trust signals</li>
              <li>Evidence photos that show delivery inside real learning spaces</li>
            </ul>
            <a class="button institution-proof-link" href="/institutional-partnerships/">View the MoU evidence page</a>
          </article>
          <div class="institution-photo-grid">
            {institutionalEvidence.map((item) => (
              <figure>
                <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                <figcaption>
                  <strong>{item.title}</strong>
                  <span>{item.text}</span>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section profile-section" id="team" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>The team accountable for the work.</h2>
          <p class="section-lede">
            Programme direction, field management, content, media, and gender perspectives are led by a visible team accountable for delivery.
          </p>
        </div>
        <div class="team-grid">
          {teamProfiles.map((profile) => (
            <article class="profile-card team-card">
              <img src={profile.image} alt={profile.name} loading="lazy" decoding="async" />
              <div class="profile-card-body">
                <span class="profile-location">{profile.role}</span>
                <h3>{profile.name}</h3>
                <p>{profile.bio}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Who Urdu Ai reached.</h2>
          <p class="section-lede">
            Phase 2 completion data includes learners across education, employment, social sector, and small business contexts.
          </p>
        </div>
        <table class="sector-table">
          <thead>
            <tr>
              <th>Reported learner group</th>
              <th>Records</th>
            </tr>
          </thead>
          <tbody>
            {sectors.map(([sector, count]) => (
              <tr>
                <td>{sector}</td>
                <td>{count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="section alt" data-reveal>
      <div class="container">
        <div class="section-head">
          <h2>Media coverage.</h2>
          <p class="section-lede">
            National and regional media coverage helps document Urdu Ai's public visibility and momentum.
            Source: Urdu Ai in Media channel.
          </p>
        </div>
        <div class="media-grid">
          {mediaVideos.map(([id, title]) => (
            <article class="media-card">
              <iframe src={`https://www.youtube.com/embed/${id}`} title={title} loading="lazy" allowfullscreen></iframe>
              <p>{title}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section partner-ask-section" id="partner" data-reveal>
      <div class="container partner-ask">
        <div class="partner-ask-copy">
          <span class="eyebrow">Partner pathway</span>
          <h2>Where funding can take Urdu Ai next.</h2>
          <p>
            Urdu Ai already has the ingredients that funders look for: trusted field delivery, national attention, women participation, district evidence, media visibility, and a practical language-access thesis. The next step is deeper, better-measured learning pathways.
          </p>
          <div class="evidence-pack" aria-label="Evidence available for partners">
            <strong>Evidence available for partner review</strong>
            <ul>
              {evidencePack.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <a class="button" href="mailto:ai@urduai.org">Discuss partnership</a>
        </div>
        <div class="funding-grid">
          {fundingPriorities.map((item) => (
            <article class="funding-card">
              <span>{item.label}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <em>{item.proof}</em>
            </article>
          ))}
        </div>
      </div>
    </section>

