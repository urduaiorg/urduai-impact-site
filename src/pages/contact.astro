---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact Urdu Ai Impact"
  description="Contact Urdu Ai for partnerships, questions, and opportunities to work together on Urdu-first AI literacy."
>
  <main>
    <section class="contact-hero">
      <div class="container contact-panel">
        <div class="contact-copy">
          <h1>Contact Urdu Ai.</h1>
          <p class="urdu-line">مصنوعی ذہانت کو آسان اردو میں عام لوگوں تک پہنچانے کے لئے ہم سے رابطہ کریں</p>
          <p>
            For partners, questions, media, field evidence, or working together on Urdu-first AI literacy, reach the Urdu Ai team directly.
          </p>
          <a class="button" href="mailto:ai@urduai.org">ai@urduai.org</a>
        </div>
        <div class="contact-card" aria-label="Contact reasons">
          <h2>Write to us for</h2>
          <ul>
            <li>Partnerships and collaboration</li>
            <li>Questions about Urdu Ai impact and reporting</li>
            <li>Working together on AI literacy, field training, media, or community delivery</li>
          </ul>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
