---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { impactNotes } from "../../data/impactNotes.js";

export function getStaticPaths() {
  return impactNotes.map((note) => ({
    params: { slug: note.slug },
    props: { note }
  }));
}

const { note } = Astro.props;
const canonical = `https://impact.urduai.org/impact-notes/${note.slug}/`;
const displayDate = new Date(`${note.date}T00:00:00`).toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
});
const articleBody = note.sections
  .flatMap((section) => [section.heading, ...section.body])
  .join("\n\n");
const wordCount = articleBody.split(/\s+/).filter(Boolean).length;
const articleSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": canonical,
      "url": canonical,
      "headline": note.title,
      "description": note.description,
      "image": {
        "@type": "ImageObject",
        "url": new URL(note.image, "https://impact.urduai.org").href,
        "width": 1200,
        "height": 750
      },
      "datePublished": note.date,
      "dateModified": note.date,
      "author": {
        "@type": "Organization",
        "name": note.author ?? "Urdu Ai",
        "url": "https://urduai.org/"
      },
      "reviewedBy": note.reviewedBy ? {
        "@type": "Organization",
        "name": note.reviewedBy,
        "url": "https://wang.org.pk/about.html"
      } : undefined,
      "publisher": {
        "@type": "Organization",
        "name": "Urdu Ai Impact",
        "url": "https://impact.urduai.org/",
        "logo": {
          "@type": "ImageObject",
          "url": "https://impact.urduai.org/assets/urdu-ai-logo-og.png"
        }
      },
      "articleSection": note.category,
      "keywords": note.keywords.join(", "),
      "inLanguage": "en",
      "wordCount": wordCount,
      "about": note.keywords,
      "citation": note.sources?.map((source) => source.href),
      "articleBody": articleBody,
      "mainEntityOfPage": canonical
    },
    {
      "@type": "FAQPage",
      "mainEntity": note.faqs.map((faq) => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Urdu Ai Impact",
          "item": "https://impact.urduai.org/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Impact Notes",
          "item": "https://impact.urduai.org/impact-notes/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": note.title,
          "item": canonical
        }
      ]
    }
  ]
};
---

<BaseLayout title={note.seoTitle} description={note.description} canonical={canonical} ogImage={note.image}>
  <main>
    <article class="article-shell">
      <header class="article-hero">
        <div class="container article-hero-grid">
          <div>
            <a class="article-back-link" href="/impact-notes/">Impact Notes</a>
            <span class="eyebrow">{note.category}</span>
            <h1>{note.title}</h1>
            <p class="article-deck">{note.description}</p>
            <div class="article-meta">
              <span>By {note.author ?? "Urdu Ai"}</span>
              <span>{displayDate}</span>
              <span>{note.readingTime}</span>
              {note.reviewedBy && <span>Reviewed by WANG</span>}
            </div>
          </div>
          <figure>
            {note.imageWebp ? (
              <picture>
                <source srcset={note.imageWebp} type="image/webp" />
                <img src={note.image} alt={note.title} loading="eager" decoding="async" width="1200" height="750" />
              </picture>
            ) : (
              <img src={note.image} alt={note.title} loading="eager" decoding="async" />
            )}
            <figcaption>Urdu Ai field learning and community AI education in Pakistan.</figcaption>
          </figure>
        </div>
      </header>

      <div class="container article-layout">
        <aside class="article-sidebar" aria-label="Article summary and links">
          <div class="article-side-card">
            <strong>Who this is for</strong>
            <p>{note.audience}</p>
          </div>
          <div class="article-side-card">
            <strong>Key takeaways</strong>
            <ul>
              {note.takeaways.map((takeaway) => <li>{takeaway}</li>)}
            </ul>
          </div>
          <div class="article-side-card">
            <strong>Related links</strong>
            <nav>
              {note.links.map((link) => (
                <a href={link.href}>{link.label}</a>
              ))}
            </nav>
          </div>
          {note.sources && (
            <div class="article-side-card">
              <strong>Sources and recognition</strong>
              <nav>
                {note.sources.map((source) => (
                  <a href={source.href}>{source.label}</a>
                ))}
              </nav>
            </div>
          )}
        </aside>

        <div class="article-content">
          {note.sections.map((section) => (
            <section>
              <h2>{section.heading}</h2>
              {section.body.map((paragraph) => <p>{paragraph}</p>)}
              {section.image && (
                <figure class="article-inline-image">
                  {section.image.webp ? (
                    <picture>
                      <source srcset={section.image.webp} type="image/webp" />
                      <img src={section.image.src} alt={section.image.alt} loading="lazy" decoding="async" width="1200" height="750" />
                    </picture>
                  ) : (
                    <img src={section.image.src} alt={section.image.alt} loading="lazy" decoding="async" />
                  )}
                  {section.image.caption && <figcaption>{section.image.caption}</figcaption>}
                </figure>
              )}
            </section>
          ))}

          <section class="article-faq">
            <h2>Common questions</h2>
            {note.faqs.map((faq) => (
              <details>
                <summary>{faq.question}</summary>
                <p>{faq.answer}</p>
              </details>
            ))}
          </section>

          <section class="article-cta">
            <h2>Partner with <span class="brand-inline on-dark"><span>Urdu</span> <span>Ai</span></span></h2>
            <p>
              <span class="brand-inline on-dark"><span>Urdu</span> <span>Ai</span></span> is building practical AI literacy pathways through Urdu-first learning, Dost facilitators, institutional partners, and community access across Pakistan.
            </p>
            <div>
              <a class="button" href="/contact/">Discuss partnership</a>
              <a class="button secondary" href="/institutional-partnerships/">View institutional MoUs</a>
            </div>
          </section>
        </div>
      </div>
    </article>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>
